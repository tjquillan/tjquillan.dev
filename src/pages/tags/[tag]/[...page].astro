---
import type { GetStaticPathsOptions } from "astro";

import PostCard from "../../../components/PostCard.astro";
import { CONFIG } from "../../../config";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import {
  getPostsByTag,
  getPublishedPosts,
  getTagSlug,
  getUniqueTags,
} from "../../../lib/blog";
import { getNormalizedPathname } from "../../../lib/url";

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const posts = await getPublishedPosts();
  const tags = getUniqueTags(posts);

  return tags.flatMap((tag) => {
    const tagPosts = getPostsByTag(tag, posts);

    return paginate(tagPosts, {
      params: { tag: getTagSlug(tag) },
      props: { tag: tag },
      pageSize: CONFIG.postPerPage,
    });
  });
}

const { page, tag } = Astro.props;

const title = `Tag: ${tag}`;
const description = `All the articles with the tag "${tag}".`;
---

<BaseLayout title={title} description={description}>
  <main class="app-layout mt-8 pb-4">
    <h1 class="text-2xl font-semibold sm:text-3xl">
      Tag: <span transition:name={getNormalizedPathname(Astro.url)}>{tag}</span>
    </h1>
    <p class="mt-2 mb-6 italic">{description}</p>
    <ul>
      {page.data.map((post) => <PostCard post={post} />)}
    </ul>
  </main>
</BaseLayout>
