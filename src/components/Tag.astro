---
import IconHash from "@tabler/icons/outline/hash.svg";

import { getTagSlug, getTagUrl } from "@/lib/blog";

type Props = {
  tag: string;
  size?: "sm" | "lg";
};

const { tag, size = "lg" } = Astro.props;
const tagSlug = getTagSlug(tag);
const tagUrl = getTagUrl(tagSlug);
---

<li>
  <a
    href={tagUrl}
    transition:name={tagUrl}
    class:list={[
      "flex items-center gap-0.5 border-b-2 border-dashed border-foreground hover:-mt-0.5 hover:border-accent hover:text-accent focus-visible:border-none focus-visible:text-accent",
      { "text-sm": size === "sm" },
      { "text-lg": size === "lg" },
    ]}
  >
    <IconHash
      class:list={[
        "opacity-80",
        { "size-5": size === "lg" },
        { "size-4": size === "sm" },
      ]}
    />
    {tag}
  </a>
</li>
